{
  "name": "carpenter-master-calc",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "verify-math": "npx tsx scripts/verify-math.ts",
    "verify-input": "npx tsx scripts/verify-calculator-input.ts",
    "verify-chain": "npx tsx scripts/verify-calculator-chain.ts",
    "verify-store": "npx tsx scripts/verify-calculator-store.ts",
    "verify-sequential": "npx tsx scripts/verify-calculator-sequential.ts",
    "verify-all": "npm run verify-math && npm run verify-input && npm run verify-store && npm run verify-sequential",
    "typecheck": "tsc --noEmit"
  },
  "private": true
}
